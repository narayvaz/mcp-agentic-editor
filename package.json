{
  "name": "mcp-agentic-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "author": "Azat Television",
  "description": "MCP Agentic Editor - Native Desktop App",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "NODE_ENV=production tsx server.ts",
    "build": "vite build",
    "build:server": "tsup server.ts --out-dir dist-server --format esm --clean",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-server dist-electron release",
    "lint": "tsc --noEmit",
    "electron:dev": "NODE_ENV=development concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron -r tsx/register electron/main.ts\"",
    "electron:build": "npm run build && npm run build:server && npm run build:electron && electron-builder"
  },
  "build": {
    "appId": "com.mcp.editor",
    "productName": "MCP Agentic Editor",
    "artifactName": "MCP-Agentic-Editor-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "dist-electron/**/*",
      "package.json",
      ".env"
    ],
    "mac": {
      "category": "public.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "narayvaz",
      "repo": "mcp-agentic-editor"
    }
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "electron-updater": "^6.6.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  }
}
